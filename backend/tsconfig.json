{
  "compilerOptions": {
    "target": "ES2020",

    "module": "Node16",
    "moduleResolution": "node16",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "types": ["node"],

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "ignoreDeprecations": "6.0"
  },

  "include": ["src"],
  "exclude": ["node_modules"]
}